# ============================================================================
#  CollectRefunds settings
#
#  To run on your own computer, you don't need to change ANYTHING here — the
#  defaults work and text messages print to your screen instead of sending.
#
#  You only fill in the values below when you're ready to put the site online.
#  Every line has a plain-English note explaining it.
# ============================================================================

# The name shown in the header and in text messages.
SITE_NAME=CollectRefunds

# ---------------------------------------------------------------------------
#  ONLY NEEDED WHEN GOING LIVE  (leave as-is for local testing)
# ---------------------------------------------------------------------------

# Your website address, no slash at the end. Example: https://collectrefunds.com
BASE_URL=http://localhost:8000

# Flip to "production" only on the real server. Keep "development" locally.
ENVIRONMENT=development

# A random password that protects the /admin page.
# Generate one by running:  make secrets
ADMIN_PASSWORD=

# A long random string that signs security tokens. Also from:  make secrets
SECRET_KEY=

# Your support email. Shown on the site and in the "reply HELP" text.
CONTACT_EMAIL=you@example.com

# ---------------------------------------------------------------------------
#  TEXT MESSAGES (Twilio)  — leave ALL of these blank to test for free.
#  Blank = codes and alerts print to your screen. Fill in only when you have a
#  Twilio account and want texts to actually send. See the README, "Part 2".
# ---------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=

# ---------------------------------------------------------------------------
#  PRO PAYMENTS (Stripe)  — leave blank to keep Pro switched off.
#  Blank = the "Get Pro" button politely says "coming soon". Fill these in from
#  your Stripe dashboard when you're ready to charge. See README "Part 4".
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
PRO_PRICE_DISPLAY=$4/mo

# ---------------------------------------------------------------------------
#  You almost never need to touch anything below this line.
# ---------------------------------------------------------------------------

# Who the scraper says it is to the FTC. Put your real domain + email here
# before going live, or government sites may block you.
USER_AGENT=CollectRefunds/2.0 (+http://localhost; you@example.com)

# Where data is stored. The default SQLite file is fine for one small server.
DATABASE_URL=sqlite:///./claimwatch.db

# How often to check the FTC for new programs, in minutes.
INGEST_INTERVAL_MINUTES=180

# Programs the scraper is less than this confident about wait for your approval
# in /admin before showing publicly. 0.6 is a sensible default.
REVIEW_THRESHOLD=0.6

# Leave false. The background worker handles scraping so the website stays fast.
RUN_SCHEDULER_IN_WEB=false

# Used only by Docker for the database and HTTPS.
POSTGRES_PASSWORD=
SITE_DOMAIN=localhost

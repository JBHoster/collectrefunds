# Caddy terminates TLS and fetches certificates automatically.
# Replace the hostname, point an A record at the server, and it just works.
{$SITE_DOMAIN:localhost} {
	encode zstd gzip

	# Long cache for fingerprint-free static assets is fine; they're small and rarely change.
	@static path /static/*
	header @static Cache-Control "public, max-age=86400"

	# Never let a stale CDN cache serve a wrong claim deadline.
	@pages path /programs/* /
	header @pages Cache-Control "public, max-age=300, must-revalidate"

	reverse_proxy web:8000 {
		health_uri /healthz
		health_interval 30s
	}
}
